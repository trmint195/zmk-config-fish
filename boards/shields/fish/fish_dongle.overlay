#include "fish.dtsi"
#include <dt-bindings/xiaord/input_codes.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

// Dongle has no physical matrix — disable the gpio kscan and use xiaord's mock kscan.
&kscan0 {
    status = "disabled";
};

/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };
};

// ============================================================
// home_button overrides (samples — uncomment to override)
//
// INPUT_VIRTUAL_SYM_* enum definitions:
//   zmk_modules/zmk-module-xiaord/include/dt-bindings/xiaord/input_codes.h
//
// Each symbol maps 1:1 to an LVGL LV_SYMBOL_* icon.
// Icon reference: https://docs.lvgl.io/9.0/overview/font.html
// ============================================================
// &home_button_0 { code = <INPUT_VIRTUAL_SYM_UPLOAD>; };    /* 12 o'clock */
&home_button_1 { code = <INPUT_VIRTUAL_SYM_KEYBOARD>; };     /*  1 o'clock — overridden: IMAGE → KEYBOARD */
// &home_button_2 { code = <INPUT_VIRTUAL_SYM_VOLUME_MAX>; }; /*  2 o'clock */
// &home_button_3 { code = <INPUT_VIRTUAL_SYM_MUTE>; };       /*  3 o'clock */
// &home_button_4 { code = <INPUT_VIRTUAL_SYM_VOLUME_MID>; }; /*  4 o'clock */
// &home_button_5 { code = <INPUT_VIRTUAL_SYM_NEXT>; };       /*  5 o'clock */
// &home_button_6 { code = <INPUT_VIRTUAL_SYM_PLAY>; };       /*  6 o'clock */
// &home_button_7 { code = <INPUT_VIRTUAL_SYM_PREV>; };       /*  7 o'clock */
// &home_button_8 { code = <INPUT_VIRTUAL_SYM_WARNING>; };    /*  8 o'clock */
// &home_button_9 { code = <INPUT_VIRTUAL_SYM_USB>; };        /*  9 o'clock */
// &home_button_10 { code = <INPUT_VIRTUAL_SYM_BLUETOOTH>; nav-page = <XIAORD_PAGE_BT>; };    /* 10 o'clock */
// &home_button_11 { code = <INPUT_VIRTUAL_SYM_SETTINGS>; nav-page = <XIAORD_PAGE_CLOCK>; }; /* 11 o'clock */

// ============================================================
// virtual_symbol_behavior override (full replacement)
// Default (from zmk_behaviors.dtsi) is shown below for reference:
//
// &virtual_symbol_behavior {
//     codes = <
//         INPUT_VIRTUAL_SYM_UPLOAD
//         INPUT_VIRTUAL_SYM_MUTE
//         INPUT_VIRTUAL_SYM_VOLUME_MID    INPUT_VIRTUAL_SYM_VOLUME_MAX
//         INPUT_VIRTUAL_SYM_IMAGE
//         INPUT_VIRTUAL_SYM_PREV          INPUT_VIRTUAL_SYM_PLAY
//         INPUT_VIRTUAL_SYM_PAUSE         INPUT_VIRTUAL_SYM_STOP
//         INPUT_VIRTUAL_SYM_NEXT
//         INPUT_VIRTUAL_SYM_WARNING
//         INPUT_VIRTUAL_SYM_USB           INPUT_VIRTUAL_SYM_BLUETOOTH
//     >;
//     bindings = <
//         &bootloader
//         &kp C_MUTE
//         &kp C_VOL_DN                    &kp C_VOL_UP
//         &kp PRINTSCREEN
//         &kp C_PREV                      &kp C_PLAY
//         &kp C_PAUSE                     &kp C_STOP
//         &kp C_NEXT
//         &kp LC(LA(DEL))
//         &out OUT_USB                    &out OUT_BLE
//     >;
// };
// ============================================================
&virtual_symbol_behavior {
    codes = <
        INPUT_VIRTUAL_SYM_UPLOAD
        INPUT_VIRTUAL_SYM_MUTE
        INPUT_VIRTUAL_SYM_VOLUME_MID    INPUT_VIRTUAL_SYM_VOLUME_MAX
        INPUT_VIRTUAL_SYM_KEYBOARD
        INPUT_VIRTUAL_SYM_PREV          INPUT_VIRTUAL_SYM_PLAY
        INPUT_VIRTUAL_SYM_PAUSE         INPUT_VIRTUAL_SYM_STOP
        INPUT_VIRTUAL_SYM_NEXT
        INPUT_VIRTUAL_SYM_WARNING
        INPUT_VIRTUAL_SYM_USB           INPUT_VIRTUAL_SYM_BLUETOOTH
    >;
    bindings = <
        &bootloader
        &kp C_MUTE
        &kp C_VOL_DN                    &kp C_VOL_UP
        &kp CAPSLOCK
        &kp C_PREV                      &kp C_PLAY
        &kp C_PAUSE                     &kp C_STOP
        &kp C_NEXT
        &kp LC(LA(DEL))
        &out OUT_USB                    &out OUT_BLE
    >;
};
